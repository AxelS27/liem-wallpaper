import { Button, CheckBox, Slider, ComboBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Liem Wallpaper Settings";
    preferred-width: 640px;
    preferred-height: 580px;
    background: @linear-gradient(135deg, #0f0c1b 0%, #15102a 50%, #0d0b18 100%);
    default-font-family: "Outfit";
    default-font-size: 14px;

    // Data-bindings from Rust
    in-out property <string> daemon-status: "Connecting...";
    in-out property <bool> is-connected: false;
    in-out property <string> current-wallpaper: "None";
    in-out property <string> active-effect: "fade";
    in-out property <int> duration-ms: 1000;
    in-out property <bool> scheduler-enabled: true;
    in-out property <int> scheduler-interval: 15;
    in-out property <string> active-easing: "ease-in-out";
    in-out property <bool> run-on-startup: false;
    in-out property <string> update-status: "v0.1.0";
    in-out property <bool> update-available: false;
    in-out property <string> latest-version-url: "";

    // Callbacks to Rust
    callback apply-settings(string, int, bool, int, string, bool);
    callback trigger-next();
    callback check-for-updates();
    callback apply-update();

    VerticalLayout {
        padding: 24px;
        spacing: 20px;

        // Header Section
        HorizontalLayout {
            spacing: 12px;
            alignment: space-between;

            VerticalLayout {
                spacing: 4px;
                Text {
                    text: "Liem Wallpaper";
                    font-size: 26px;
                    font-weight: 800;
                    color: #ffffff;
                }
                Text {
                    text: "GPU-Accelerated Desktop Transitions";
                    font-size: 13px;
                    color: #a09cb0;
                }
            }

            // Connection Status Badge
            Rectangle {
                border-radius: 12px;
                background: root.is-connected ? #10b9811f : #ef44441f;
                border-color: root.is-connected ? #10b981 : #ef4444;
                border-width: 1px;
                height: 28px;
                width: 130px;
                y: 10px;

                HorizontalLayout {
                    alignment: center;
                    spacing: 6px;
                    y: 6px;
                    Rectangle {
                        border-radius: 4px;
                        width: 8px;
                        height: 8px;
                        background: root.is-connected ? #10b981 : #ef4444;
                    }
                    Text {
                        text: root.daemon-status;
                        color: root.is-connected ? #10b981 : #ef4444;
                        font-size: 11px;
                        font-weight: 700;
                    }
                }
            }
        }

        // Current Wallpaper Banner (Glassmorphism Effect)
        Rectangle {
            background: #ffffff08;
            border-radius: 12px;
            border-width: 1px;
            border-color: #ffffff14;

            VerticalLayout {
                padding: 12px;
                spacing: 6px;
                Text {
                    text: "ACTIVE WALLPAPER";
                    font-size: 10px;
                    font-weight: 700;
                    color: #8b5cf6;
                }
                Text {
                    text: root.current-wallpaper;
                    font-size: 13px;
                    color: #e2e8f0;
                    font-family: "Consolas";
                }
            }
        }

        // Transition Settings Section
        Rectangle {
            background: #ffffff04;
            border-radius: 12px;
            border-width: 1px;
            border-color: #ffffff0a;

            VerticalLayout {
                padding: 16px;
                spacing: 16px;

                Text {
                    text: "TRANSITION CONFIGURATION";
                    font-size: 11px;
                    font-weight: 700;
                    color: #8b5cf6;
                }

                // Effect Grid
                HorizontalLayout {
                    spacing: 16px;
                    alignment: space-between;

                    Text {
                        text: "Transition Effect:";
                        color: #cbd5e1;
                        vertical-alignment: center;
                    }

                    effect-select := ComboBox {
                        current-value: root.active-effect;
                        model: ["fade", "wipe", "slide"];
                        width: 180px;
                    }
                }

                // Easing Curve
                HorizontalLayout {
                    spacing: 16px;
                    alignment: space-between;

                    Text {
                        text: "Easing Mode:";
                        color: #cbd5e1;
                        vertical-alignment: center;
                    }

                    easing-select := ComboBox {
                        current-value: root.active-easing;
                        model: ["ease-in-out", "ease-in", "ease-out", "linear"];
                        width: 180px;
                    }
                }

                // Duration Slider
                VerticalLayout {
                    spacing: 6px;
                    HorizontalLayout {
                        alignment: space-between;
                        Text {
                            text: "Transition Duration:";
                            color: #cbd5e1;
                        }
                        Text {
                            text: Math.round(duration-slider.value) + " ms";
                            color: #8b5cf6;
                            font-weight: 700;
                        }
                    }
                    duration-slider := Slider {
                        minimum: 100;
                        maximum: 3000;
                        value: root.duration-ms;
                    }
                }
            }
        }

        // Rotation Scheduler Settings Section
        Rectangle {
            background: #ffffff04;
            border-radius: 12px;
            border-width: 1px;
            border-color: #ffffff0a;

            VerticalLayout {
                padding: 16px;
                spacing: 16px;

                Text {
                    text: "ROTATION SCHEDULER";
                    font-size: 11px;
                    font-weight: 700;
                    color: #8b5cf6;
                }

                // Enable Switch
                HorizontalLayout {
                    alignment: space-between;
                    Text {
                        text: "Enable Background Rotation:";
                        color: #cbd5e1;
                        vertical-alignment: center;
                    }
                    scheduler-check := CheckBox {
                        checked: root.scheduler-enabled;
                        text: "";
                    }
                }

                // Run on Startup Toggle
                HorizontalLayout {
                    alignment: space-between;
                    Text {
                        text: "Launch on Windows Startup:";
                        color: #cbd5e1;
                        vertical-alignment: center;
                    }
                    startup-check := CheckBox {
                        checked: root.run-on-startup;
                        text: "";
                    }
                }

                // Interval Slider (minutes)
                VerticalLayout {
                    spacing: 6px;
                    HorizontalLayout {
                        alignment: space-between;
                        Text {
                            text: "Rotation Interval:";
                            color: #cbd5e1;
                        }
                        Text {
                            text: Math.round(interval-slider.value) + " minutes";
                            color: #8b5cf6;
                            font-weight: 700;
                        }
                    }
                    interval-slider := Slider {
                        minimum: 1;
                        maximum: 120;
                        value: root.scheduler-interval;
                        enabled: scheduler-check.checked;
                    }
                }
            }
        }

        // Update Card
        Rectangle {
            background: #ffffff04;
            border-radius: 12px;
            border-width: 1px;
            border-color: #ffffff0a;

            VerticalLayout {
                padding: 12px;
                spacing: 10px;

                HorizontalLayout {
                    alignment: space-between;
                    
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: "Software Version:";
                            color: #cbd5e1;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: root.update-status;
                            color: root.update-available ? #f59e0b : #10b981;
                            font-weight: 700;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                    }

                    // Check / Apply Button
                    Rectangle {
                        background: update-touch.has-hover ? #ffffff1f : #ffffff0e;
                        border-radius: 6px;
                        height: 28px;
                        width: 150px;
                        border-width: 1px;
                        border-color: #ffffff14;

                        update-touch := TouchArea {
                            clicked => {
                                if (root.update-available) {
                                    root.apply-update();
                                } else {
                                    root.check-for-updates();
                                }
                            }
                        }

                        HorizontalLayout {
                            alignment: center;
                            Text {
                                text: root.update-available ? "Install Update" : "Check for Updates";
                                color: #ffffff;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        // Action Buttons Section
        HorizontalLayout {
            spacing: 16px;

            // Trigger Next Button (Secondary Style)
            Rectangle {
                background: next-touch.has-hover ? #ffffff1f : #ffffff0e;
                border-radius: 8px;
                height: 44px;
                width: 180px;
                border-width: 1px;
                border-color: #ffffff18;

                next-touch := TouchArea {
                    clicked => {
                        root.trigger-next();
                    }
                }

                HorizontalLayout {
                    alignment: center;
                    spacing: 8px;
                    y: 12px;
                    Text {
                        text: "Skip Wallpaper";
                        color: #ffffff;
                        font-weight: 700;
                    }
                }
            }

            // Apply Settings Button (Primary Style Accent)
            Rectangle {
                background: apply-touch.has-hover ? #7c3aed : #6d28d9;
                border-radius: 8px;
                height: 44px;
                horizontal-stretch: 1;

                apply-touch := TouchArea {
                    clicked => {
                        root.apply-settings(
                            effect-select.current-value,
                            Math.round(duration-slider.value),
                            scheduler-check.checked,
                            Math.round(interval-slider.value),
                            easing-select.current-value,
                            startup-check.checked
                        );
                    }
                }

                HorizontalLayout {
                    alignment: center;
                    spacing: 8px;
                    y: 12px;
                    Text {
                        text: "Apply Settings";
                        color: #ffffff;
                        font-weight: 700;
                    }
                }
            }
        }
    }
}
